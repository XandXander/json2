    {
      "parameters": {
        "jsCode": "const response = $input.first().json;\nconst prevData = $('Merge After Voice Check').first().json;\n\nlet parsed;\ntry {\n  const content = response.choices?.[0]?.message?.content || '{}';\n  parsed = JSON.parse(content);\n} catch (e) {\n  parsed = {\n    intent: 'search_private',\n    entities: { keywords: [] },\n    confidence: 0\n  };\n}\n\nconst jobId = crypto.randomUUID();\nconst createdAt = new Date().toISOString();\n\nreturn [{\n  json: {\n    job_id: jobId,\n    created_at: createdAt,\n    source: prevData.source,\n    user_id: prevData.user_id,\n    chat_id: prevData.chat_id,\n    raw_text: prevData.raw_text,\n    intent: parsed.intent || 'search_private',\n    entities: parsed.entities || {},\n    confidence: parsed.confidence || 0,\n    status: 'processing'\n  }\n}];"
      },
