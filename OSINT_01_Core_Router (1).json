    {
      "parameters": {
        "jsCode": "const text = ($json.raw_text || '').trim();\nconst lower = text.toLowerCase();\n\n// Стоп-слова: явно не OSINT-запросы\nconst blocklist = [\n  'github', 'no-reply', 'noreply', 'password', 'verify your',\n  'confirm your', 'unsubscribe', 'security alert', 'sign-in',\n  'account was', 'access token', 'newsletter', 'promo',\n  'invoice', 'receipt', 'welcome to', 'reset your'\n];\n\nconst isSpam = blocklist.some(w => lower.includes(w));\nconst isTooShort = text.length < 15;\nconst isTooLong = text.length > 2000;\n\nif (isSpam || isTooShort || isTooLong) {\n  // Молча отбрасываем — не идём в Groq\n  return [];\n}\n\n// Идемпотентность без crypto\nlet hash = 0;\n\nfor (let i = 0; i < text.length; i++) {\n  hash = ((hash << 5) - hash + text.charCodeAt(i)) | 0;\n}\n\nconst requestHash = Math.abs(hash).toString(16);\n\nreturn [{\n  json: {\n    ...$json,\n    request_hash: requestHash,\n  },\n}];"
      },
