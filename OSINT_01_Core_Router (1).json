    {
      "parameters": {
        "jsCode": "const results = [];\n\nfor (const item of $input.all()) {\n  const data = item.json;\n  let normalized = {\n    source: null,\n    user_id: null,\n    chat_id: null,\n    raw_text: '',\n    voice_file_id: null,\n    timestamp: new Date().toISOString()\n  };\n  \n  // Telegram message\n  if (data.message || data.edited_message || data.callback_query) {\n    normalized.source = 'telegram';\n    const msg = data.message || data.edited_message || data.callback_query?.message;\n    const from = data.message?.from || data.edited_message?.from || data.callback_query?.from;\n    \n    normalized.user_id = from?.id?.toString() || null;\n    normalized.chat_id = msg?.chat?.id?.toString() || null;\n    \n    if (data.callback_query) {\n      normalized.raw_text = data.callback_query.data || '';\n    } else if (msg?.voice) {\n      normalized.voice_file_id = msg.voice.file_id;\n      normalized.raw_text = msg.caption || '';\n    } else {\n      normalized.raw_text = msg?.text || msg?.caption || '';\n    }\n  }\n  // Email\n  else if (data.subject !== undefined || data.from?.value) {\n    normalized.source = 'email';\n    normalized.user_id = data.from?.value?.[0]?.address || data.from || 'email_user';\n    normalized.chat_id = null;\n    normalized.raw_text = (data.subject || '') + '\\n' + (data.text || data.textPlain || '');\n  }\n  // Google Sheets queued job\n  else if (data.status === 'queued_manual' || data.raw_text) {\n    normalized.source = 'sheets';\n    normalized.user_id = data.user_id || 'sheets_user';\n    normalized.chat_id = data.chat_id || null;\n    normalized.raw_text = data.raw_text || data.query || '';\n  }\n  \n  // Skip empty\n  if (normalized.raw_text || normalized.voice_file_id) {\n    results.push({ json: normalized });\n  }\n}\n\nreturn results.length > 0 ? results : [{ json: { source: 'empty', raw_text: '', user_id: null, chat_id: null, voice_file_id: null, timestamp: new Date().toISOString() } }];"
      },
